# Copy this file to .env.local and fill in the value.
# .env.local is gitignored; .env.example is committed.

# Google OAuth 2.0 Client ID used for Drive auto-sync.
# Create one in Google Cloud Console → APIs & Services → Credentials →
# Create OAuth client ID → Application type: Web application.
# Add http://localhost:5173 (and any prod origin) to Authorized JavaScript origins.
# Scope used by the app: https://www.googleapis.com/auth/drive.appdata
VITE_GOOGLE_CLIENT_ID=
